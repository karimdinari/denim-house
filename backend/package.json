{
  "name": "denim-house-backend",
  "version": "1.0.0",
  "description": "Denim House R&D Workspace — Backend API",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "dev":              "nodemon src/index.js",
    "start":            "node src/index.js",
    "prisma:migrate":   "prisma migrate dev",
    "prisma:generate":  "prisma generate",
    "prisma:studio":    "prisma studio",
    "prisma:reset":     "prisma migrate reset --force",
    "prisma:seed":      "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client":   "^5.14.0",
    "bcrypt":           "^5.1.1",
    "bull":             "^4.12.9",
    "cors":             "^2.8.5",
    "dotenv":           "^16.4.5",
    "express":          "^4.19.2",
    "ioredis":          "^5.4.1",
    "jsonwebtoken":     "^9.0.2",
    "socket.io":        "^4.7.5"
  },
  "devDependencies": {
    "nodemon":          "^3.1.4",
    "prisma":           "^5.14.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}